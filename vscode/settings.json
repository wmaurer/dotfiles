{
    "editor.fontFamily": "Hasklig, 'Source Code Pro', Consolas, 'Courier New', monospace",
    "editor.fontLigatures": true,
    "editor.minimap.enabled": false,
    "editor.renderWhitespace": "boundary",
    "files.insertFinalNewline": true,
    "files.trimTrailingWhitespace": true,
    "vim.easymotion": true,
    "vim.enableNeovim": true,
    "vim.neovimPath": "C:\\tools\\Neovim\\bin\\nvim",
    "vim.otherModesKeyBindingsNonRecursive": [
        { "before": ["<C-r>"], "after": [], "commands": [{ "command": "workbench.action.openRecent", "args": [] }] }
    ],
    "vim.useCtrlKeys": true,
    "vim.useSystemClipboard": true,
    "vsicons.dontShowConfigManuallyChangedMessage": true,
    "vsicons.dontShowNewVersionMessage": true,
    "vsicons.projectDetection.autoReload": true,
    "window.zoomLevel": 0,
    "workbench.colorTheme": "Dark Chrome DevTools",
    "workbench.iconTheme": "vscode-icons",
    "workbench.startupEditor": "newUntitledFile",
    "vim.disableExtension": false
}
