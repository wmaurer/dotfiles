// Place your key bindings in this file to overwrite the defaults
[
    {
        "key": "ctrl+q",
        "command": "esQuotes.transformBetweenSingleDoubleQuotes",
        "when": "editorTextFocus"
    },
    {
        "key": "alt+q",
        "command": "esQuotes.transformToTemplateString",
        "when": "editorTextFocus"
    },
    {
        "key": "shift+enter w",
        "command": "extension.jumpy-word",
        "when": "editorTextFocus"
    },
    {
        "key": "shift+enter l",
        "command": "extension.jumpy-line",
        "when": "editorTextFocus"
    },
    {
        "key": "Escape",
        "command": "extension.jumpy-exit",
        "when": "editorTextFocus && jumpy.isJumpyMode"
    },
    {
        "key": "ctrl+k shift+8",
        "command": "extension.selectParenthesis",
        "when": "editorTextFocus"
    },
    {
        "key": "ctrl+k shift+9",
        "command": "extension.selectParenthesisOuter",
        "when": "editorTextFocus"
    },
    {
        "key": "ctrl+k ctrl+alt+\\",
        "command": "extension.selectCurlyBrackets",
        "when": "editorTextFocus"
    },
    {
        "key": "ctrl+k ctrl+alt+oem_8",
        "command": "extension.selectCurlyBracketsOuter",
        "when": "editorTextFocus"
    },
    {
        "key": "ctrl+k ctrl+alt+;",
        "command": "extension.selectSquareBrackets",
        "when": "editorTextFocus"
    },
    {
        "key": "ctrl+k ctrl+alt+`",
        "command": "extension.selectSquareBracketsOuter",
        "when": "editorTextFocus"
    },
    {
        "key": "ctrl+k shift+2",
        "command": "extension.selectDoubleQuote",
        "when": "editorTextFocus"
    }
]
