{
  "Import statement": {
    "prefix": "simp",
    "body": ["import { $2 } from '$1';$3"],
    "description": "Import statement"
  },
  "Import default statement": {
    "prefix": "simpd",
    "body": ["import $2 from '$1';$3"],
    "description": "Import default statement"
