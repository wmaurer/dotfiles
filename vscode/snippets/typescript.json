		"prefix": "rxdoj",
		"body": [
			".do(x => console.log($1)"
		],
		"description": "rxjs .do(x => console.log()"
	},
	"rxjs .do(x => console.log(`${JSON.stringify()}`))": {
		"prefix": "rxdoj",
		"body": [
			".do(x => console.log(`$\\{JSON.stringify($1)\\}`))"
		],
		"description": "rxjs .do(x => console.log(`${JSON.stringify()}`))"
	}
